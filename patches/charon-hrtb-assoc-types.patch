+        /// `SelfClause` entries for trait methods.
         pub fn iter_self_paths(&self) -> impl Iterator<Item = (AssocTypePath, Ty)> {
             self.iter()
-                .filter(|(path, _ty)| matches!(path.tref.base, BaseClause::SelfClause))
+                .filter_map(|(path, ty)| match path.tref.base {
+                    BaseClause::SelfClause => Some((path, ty)),
+                    BaseClause::Local(DeBruijnVar::Bound(ref id, ref clause_id))
+                        if id.is_zero() && *clause_id == TraitClauseId::ZERO =>
+                    {
+                        Some((path.pop_base(), ty))
+                    }
+                    _ => None,
+                })
         }
 
         /// Apply a substitution to the output of `iter_self_paths`.
@@ -899,7 +910,25 @@ impl UpdateItemBody<'_> {
             }
             _ => self.type_replacements.depth(),
