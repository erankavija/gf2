{
  "gates": {
    "tests": {
      "version": 1,
      "key": "tests",
      "title": "All tests pass",
      "description": "cargo test must pass",
      "stage": "postcheck",
      "mode": "auto",
      "checker": {
        "type": "exec",
        "command": "cargo test",
        "timeout_seconds": 300,
        "working_dir": null,
        "env": {},
        "pass_context": false
      },
      "reserved": {},
      "auto": true,
      "example_integration": null
    },
    "lake-build": {
      "version": 1,
      "key": "lake-build",
      "title": "Lean4 proofs compile",
      "description": "lake build must succeed on all auto-generated and hand-written Lean4 proofs",
      "stage": "postcheck",
      "mode": "auto",
      "checker": {
        "type": "exec",
        "command": "lake build",
        "timeout_seconds": 600,
        "working_dir": "proofs",
        "env": {},
        "pass_context": false
      },
      "reserved": {},
      "auto": true,
      "example_integration": null
    },
    "cargo-kani": {
      "version": 1,
      "key": "cargo-kani",
      "title": "Kani proof harnesses pass",
      "description": "cargo kani must pass all bounded model checking harnesses",
      "stage": "postcheck",
      "mode": "auto",
      "checker": {
        "type": "exec",
        "command": "cargo kani",
        "timeout_seconds": 600,
        "working_dir": null,
        "env": {},
        "pass_context": false
      },
      "reserved": {},
      "auto": true,
      "example_integration": null
    },
    "clippy": {
      "version": 1,
      "key": "clippy",
      "title": "Clippy lints pass",
      "description": "No clippy warnings allowed",
      "stage": "postcheck",
      "mode": "auto",
      "checker": {
        "type": "exec",
        "command": "cargo clippy --all-targets -- -D warnings",
        "timeout_seconds": 120,
        "working_dir": null,
        "env": {},
        "pass_context": false
      },
      "reserved": {},
      "auto": true,
      "example_integration": null
    },
    "fmt": {
      "version": 1,
      "key": "fmt",
      "title": "Code formatted",
      "description": "Code must be formatted with cargo fmt",
      "stage": "postcheck",
      "mode": "auto",
      "checker": {
        "type": "exec",
        "command": "cargo fmt --check",
        "timeout_seconds": 30,
        "working_dir": null,
        "env": {},
        "pass_context": false
      },
      "reserved": {},
      "auto": true,
      "example_integration": null
    },
    "doc-review": {
      "version": 1,
      "key": "doc-review",
      "title": "Documentation review completed",
      "description": "Confirm that necessary documentation updates were made: doc comments on public APIs (description, arguments, examples, panics, complexity), relevant design docs updated, and CLAUDE.md module map reflects any new modules.",
      "stage": "postcheck",
      "mode": "manual",
      "reserved": {},
      "auto": false,
      "example_integration": null
    },
    "code-review": {
      "version": 1,
      "key": "code-review",
      "title": "Code Review",
      "description": "AI-powered code review against gf2 project standards",
      "stage": "postcheck",
      "mode": "auto",
      "checker": {
        "type": "exec",
        "command": "./scripts/ai-review.sh",
        "timeout_seconds": 600,
        "working_dir": null,
        "env": {
          "REVIEWER_AGENT": "copilot -s --model gpt-5.3-codex"
        },
        "pass_context": true,
        "prompt_file": "./scripts/code-review-prompt.md"
      },
      "reserved": {},
      "auto": true,
      "example_integration": null
    },
    "cargo-ci": {
      "version": 1,
      "key": "cargo-ci",
      "title": "Rust CI checks pass",
      "description": "Full Rust workspace CI: build, test, clippy, fmt",
      "stage": "postcheck",
      "mode": "auto",
      "checker": {
        "type": "exec",
        "command": "cargo check --workspace --all-features && cargo test --workspace --all-features && cargo clippy --workspace --all-targets --all-features -- -D warnings && cargo fmt --all -- --check",
        "timeout_seconds": 300,
        "working_dir": null,
        "env": {},
        "pass_context": false
      },
      "reserved": {},
      "auto": true,
      "example_integration": null
    },
    "tdd-reminder": {
      "version": 1,
      "key": "tdd-reminder",
      "title": "Write tests first (TDD)",
      "description": "Reminder to write failing tests before implementation",
      "stage": "precheck",
      "mode": "manual",
      "reserved": {},
      "auto": false,
      "example_integration": null
    }
  }
}