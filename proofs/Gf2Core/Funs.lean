        let exp2 ← exp1 >>> 1#i32
        if exp2 > 0#u64
        then
          let i1 ← lift (UScalar.cast .U128 base1)
          let i2 ← lift (UScalar.cast .U128 base1)
          let i3 ← i1 * i2
          let base2 ← gfp.montgomery.redc P i3
          ok (cont (base2, exp2, result2))
        else ok (cont (base1, exp2, result2))
      else ok (done result1))
    (base, exp, result)

