def gfp.montgomery.mod_pow_mont_loop
  (P : Std.U64) (base : Std.U64) (exp : Std.U64) (result : Std.U64) :
  Result Std.U64
  := do
  loop
    (fun (base1, exp1, result1) =>
      if exp1 > 0#u64
      then
        do
        let i ← lift (exp1 &&& 1#u64)
        let result2 ←
          if i = 1#u64
          then
            let i1 ← lift (UScalar.cast .U128 result1)
